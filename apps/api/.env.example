PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fuel_carrier

# Used to sign the auth JWT stored in an httpOnly cookie.
# Must be at least 16 characters. Replace in production.
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Cookie configuration
AUTH_COOKIE_NAME=auth_token
AUTH_COOKIE_SAME_SITE=lax

# OpenAPI docs at /api/docs/internal and /api/docs/external
SWAGGER_ENABLED=true

# Super admin seed (pnpm seed:super-admin)
# Password must be strong: 12+ chars, upper, lower, number, special character
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=ChangeMe1!Strong
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
