{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "types": ["jest", "node"],
    "paths": {
      "@fuel-carrier/shared-types": ["../../packages/shared-types/src"],
      "@fuel-carrier/shared-types/*": ["../../packages/shared-types/src/*"],
      "@fuel-carrier/shared-validation": ["../../packages/shared-validation/src"],
      "@fuel-carrier/shared-validation/*": ["../../packages/shared-validation/src/*"]
    }
  },
  "include": ["src", "test", "drizzle.config.ts", "../../packages/shared-validation/src"]
}
